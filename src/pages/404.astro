---
import Base from "@/layouts/Base.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Icon from "@/components/Icon.astro";
---

<Base title="404 — page not found · angr">
  <Header />
  <main id="main" class="wrap">
    <p class="kicker">// SIGSEGV</p>
    <h1>4<span class="g">0</span>4</h1>
    <p class="msg">
      This address didn't resolve. The page you're looking for has been
      relocated, stripped, or never existed.
    </p>
    <a href="/" class="btn btn-primary">
      <Icon name="arrow-right" size={18} /> Back to angr.io
    </a>
  </main>
  <Footer />

  <style>
    .wrap {
      min-height: 60vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 5rem 1.5rem;
      gap: 1rem;
    }
    h1 {
      font-family: var(--font-mono);
      font-size: clamp(5rem, 18vw, 11rem);
      font-weight: 800;
      line-height: 0.9;
      letter-spacing: -0.04em;
    }
    h1 .g {
      color: var(--primary);
    }
    .msg {
      max-width: 36ch;
      color: var(--fg-muted);
      line-height: 1.6;
      margin-bottom: 1rem;
    }
  </style>
</Base>
