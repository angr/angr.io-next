import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import Features from "@/components/Features.astro";
import CliShowcase from "@/components/CliShowcase.astro";
import ManagementShowcase from "@/components/ManagementShowcase.astro";
import McpServer from "@/components/McpServer.astro";
