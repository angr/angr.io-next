---
import Icon from "@/components/Icon.astro";

// Capabilities the MCP server exposes (mapped from angr.mcp's tools).
const capabilities = [
  "Decompilation",
  "Control-flow graphs",
  "Disassembly",
  "Cross-references",
  "Strings",
  "Imports & exports",
  "Call graphs",
  "Function search",
];
---

<section id="mcp" class="section">
  <div class="container-page">
    <header class="section-head reveal">
      <p class="kicker">// model context protocol</p>
      <h2>angr for your AI assistant</h2>
      <p class="sub">
        angr ships an <strong>MCP server</strong>, so assistants like Claude can
        drive it directly — loading binaries, recovering control-flow graphs,
        decompiling functions, and chasing cross-references, all from a
        natural-language prompt.
      </p>
    </header>

    <div class="grid">
      <div class="run card reveal">
        <div class="term-bar">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="term-title">angr — mcp</span>
        </div>
        <pre class="run-body"><code><span class="c"># expose angr over MCP (stdio — for Claude Desktop, etc.)</span>
<span class="pr">$</span> python -m angr.mcp

<span class="c"># ...or over HTTP / SSE for remote clients</span>
<span class="pr">$</span> python -m angr.mcp --transport http</code></pre>
      </div>

      <div class="tools reveal" style="--reveal-delay: 90ms">
        <p class="tools-label"><Icon name="zap" size={16} /> Tools it exposes</p>
        <ul class="chips" role="list">
          {capabilities.map((c) => <li>{c}</li>)}
        </ul>
        <p class="note">
          Works with any MCP client. Point yours at the server and ask it to
          reverse a binary.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .section {
    padding-block: clamp(3.5rem, 7vw, 6rem);
  }
  .section-head {
    max-width: 44rem;
    margin-bottom: 2.5rem;
  }
  .section-head h2 {
    font-size: clamp(1.9rem, 4vw, 2.85rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0.75rem 0 0.9rem;
  }
  .section-head .sub {
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--fg-muted);
  }
  .section-head strong {
    color: var(--fg);
  }

  .grid {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    align-items: stretch;
  }
  @media (min-width: 880px) {
    .grid {
      grid-template-columns: 1.15fr 0.85fr;
    }
  }

  /* Terminal-style run card. */
  .run {
    overflow: hidden;
  }
  .term-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    background: var(--surface-2);
    border-bottom: 1px solid var(--line);
  }
  .dot {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 50%;
    background: var(--line-strong);
  }
  .dot:nth-child(1) {
    background: #ff5f57;
  }
  .dot:nth-child(2) {
    background: #febc2e;
  }
  .dot:nth-child(3) {
    background: #28c840;
  }
  .term-title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--fg-faint);
  }
  .run-body {
    margin: 0;
    padding: 1.25rem 1.4rem 1.5rem;
    font-family: var(--font-mono);
    font-size: clamp(0.78rem, 1.6vw, 0.9rem);
    line-height: 1.85;
    overflow-x: auto;
  }
  .run-body .pr {
    color: var(--primary);
    user-select: none;
    margin-right: 0.5rem;
  }
  .run-body .c {
    color: var(--fg-faint);
  }

  /* Tools panel. */
  .tools {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .tools-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--primary);
    margin: 0 0 1rem;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .chips li {
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: 0.6rem;
    background: var(--surface);
    font-size: 0.9rem;
    font-weight: 500;
    transition: border-color 0.18s ease;
  }
  .chips li:hover {
    border-color: var(--primary);
  }
  .note {
    margin: 1.5rem 0 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--fg-muted);
  }
</style>
