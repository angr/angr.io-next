---
import { Image } from "astro:assets";
import logo from "@/assets/logo.svg";
import Icon from "@/components/Icon.astro";

const cols = [
  {
    title: "Project",
    links: [
      { label: "Documentation", href: "https://docs.angr.io" },
      { label: "GitHub", href: "https://github.com/angr" },
      { label: "API reference", href: "https://api.angr.io" },
    ],
  },
  {
    title: "Learn",
    links: [
      { label: "Getting started", href: "https://docs.angr.io/getting-started/installing" },
      { label: "Examples", href: "https://docs.angr.io/examples" },
      { label: "Core concepts", href: "https://docs.angr.io/core-concepts/toplevel" },
      { label: "Help wanted", href: "https://docs.angr.io/introductory-errata/helpwanted" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "Discord", href: "https://discord.angr.io" },
    ],
  },
];

const year = 2026;
---

<footer class="site-footer">
  <div class="container-page">
    <div class="grid">
      <div class="about">
        <a href={import.meta.env.BASE_URL} class="brand" aria-label="angr home">
          <Image src={logo} alt="" width={30} height={30} />
          <span>angr</span>
        </a>
        <p>
          An open-source binary analysis platform, for everyone.
        </p>
        <div class="socials">
          <a href="https://github.com/angr" target="_blank" rel="noopener" aria-label="GitHub">
            <Icon name="github" size={20} />
          </a>
          <a href="https://discord.angr.io" target="_blank" rel="noopener" aria-label="Discord">
            <Icon name="discord" size={20} />
          </a>
          <a href="https://docs.angr.io" target="_blank" rel="noopener" aria-label="Documentation">
            <Icon name="book" size={20} />
          </a>
        </div>
      </div>

      {
        cols.map((col) => (
          <nav class="col" aria-label={col.title}>
            <h2>{col.title}</h2>
            <ul role="list">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} target="_blank" rel="noopener">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="bottom">
      <p>© {year} the angr project · Released under the BSD license.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--line);
    background: var(--surface);
    padding-block: clamp(3rem, 6vw, 4.5rem) 2rem;
    margin-top: 2rem;
  }
  .grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .grid {
      grid-template-columns: 1.6fr repeat(3, 1fr);
    }
  }
  .about {
    max-width: 24rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: 0.9rem;
  }
  .about p {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--fg-muted);
    margin: 0 0 1.25rem;
  }
  .socials {
    display: flex;
    gap: 0.6rem;
  }
  .socials a {
    display: inline-grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.6rem;
    border: 1px solid var(--line);
    color: var(--fg-muted);
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      transform 0.18s ease;
  }
  .socials a:hover {
    color: var(--primary);
    border-color: var(--primary);
  }

  .col h2 {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-faint);
    margin: 0 0 1rem;
  }
  .col ul {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .col a {
    font-size: 0.92rem;
    color: var(--fg-muted);
    transition: color 0.16s ease;
  }
  .col a:hover {
    color: var(--primary);
  }

  .bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    font-size: 0.85rem;
    color: var(--fg-faint);
  }
</style>
