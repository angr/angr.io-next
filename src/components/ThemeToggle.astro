---
import Icon from "@/components/Icon.astro";
---

<button
  id="theme-toggle"
  type="button"
  class="theme-toggle"
  aria-label="Toggle color theme"
  title="Toggle theme"
>
  <span class="sun"><Icon name="sun" size={18} /></span>
  <span class="moon"><Icon name="moon" size={18} /></span>
</button>

<style>
  .theme-toggle {
    display: inline-grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.6rem;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--fg-muted);
    cursor: pointer;
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      transform 0.18s ease;
  }
  .theme-toggle:hover {
    color: var(--primary);
    border-color: var(--primary);
  }
  .theme-toggle span {
    grid-area: 1 / 1;
    display: inline-grid;
    place-items: center;
    transition:
      opacity 0.25s ease,
      transform 0.35s var(--ease-out-expo);
  }
  /* Show the icon for the theme you'd switch *to*. */
  :global([data-theme="dark"]) .theme-toggle .moon,
  :global([data-theme="light"]) .theme-toggle .sun {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }
  :global([data-theme="dark"]) .theme-toggle .sun,
  :global([data-theme="light"]) .theme-toggle .moon {
    opacity: 1;
    transform: rotate(0) scale(1);
  }
</style>

<script>
  const bind = () => {
    const btn = document.getElementById("theme-toggle");
    btn?.addEventListener("click", () => {
      const next =
        document.documentElement.dataset.theme === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem("theme", next);
    });
  };
  bind();
  document.addEventListener("astro:after-swap", bind);
</script>
