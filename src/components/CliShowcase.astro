---
import manifest from "@/assets/cli/manifest.json";
import Icon from "@/components/Icon.astro";

// Cast files recorded by hero/record_cli.py — pull their URLs (for the player)
// and raw text (for the no-JS / SEO fallback).
const urlMods = import.meta.glob("../assets/cli/*.cast", {
  query: "?url",
  import: "default",
  eager: true,
}) as Record<string, string>;
const rawMods = import.meta.glob("../assets/cli/*.cast", {
  query: "?raw",
  import: "default",
  eager: true,
}) as Record<string, string>;

const byId = (mods: Record<string, string>) =>
  Object.fromEntries(
    Object.entries(mods).map(([p, v]) => [
      p.split("/").pop()!.replace(".cast", ""),
      v,
    ])
  );
const urls = byId(urlMods);
const raws = byId(rawMods);

const tabs = manifest.map((m: any) => ({
  id: m.id,
  title: m.title,
  url: urls[m.id],
}));

const transcript = (raws[manifest[0].id] || "")
  .split("\n")
  .slice(1)
  .map((line) => {
    try {
      return JSON.parse(line);
    } catch {
      return null;
    }
  })
  .filter((ev) => ev && ev[1] === "o")
  .map((ev) => ev[2])
  .join("")
  .replace(/\[[0-9;?]*[a-zA-Z]/g, "")
  .replace(/\r/g, "")
  .trimEnd();
---

<section id="applications" class="section">
  <div class="container-page">
    <header class="section-head reveal">
      <p class="kicker">// in your terminal</p>
      <h2>Straight from your shell</h2>
      <p class="sub">
        Drive angr however you like in the terminal —
        fire one-shot <strong>decompile</strong> and <strong>disassemble</strong> commands, or
        script it live in a Python <strong>REPL</strong>.
      </p>
    </header>

    <div class="player card ticked reveal" data-cli-player>
      <div class="term-bar">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
        <span class="term-title">fauxware — angr</span>
      </div>
      <div class="player-stage">
        <div
          id="cli-cast"
          class="cast-mount"
          data-cast={tabs[0].url}
          role="img"
          aria-label="Recorded angr command-line session decompiling and disassembling the fauxware binary"
        >
        </div>
        <noscript>
          <pre class="cast-fallback">{transcript}</pre>
        </noscript>
      </div>
      <div class="cli-tabs" role="tablist" aria-label="angr CLI commands">
        {
          tabs.map((t, i) => (
            <button
              class="cli-tab"
              data-tab
              data-cast={t.url}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              tabindex={i === 0 ? "0" : "-1"}
            >
              {t.title}
            </button>
          ))
        }
      </div>
    </div>

    <div class="cli-cta reveal">
      <a href="https://docs.angr.io" target="_blank" rel="noopener" class="btn btn-ghost">
        <Icon name="book" size={18} /> Read the docs
      </a>
      <a href="https://docs.angr.io/examples" target="_blank" rel="noopener" class="btn btn-ghost">
        <Icon name="arrow-up-right" size={18} /> More examples
      </a>
    </div>
  </div>
</section>

<style>
  .section {
    padding-block: clamp(3.5rem, 7vw, 6rem);
  }
  .section-head {
    max-width: 42rem;
    margin-bottom: 2.5rem;
  }
  .section-head h2 {
    font-size: clamp(1.9rem, 4vw, 2.85rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0.75rem 0 0.9rem;
  }
  .section-head .sub {
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--fg-muted);
  }
  .section-head strong {
    color: var(--fg);
  }

  .player {
    /* Width drives the asciinema font size (fit:"width"); sized for the
       110-col casts. */
    max-width: 62rem;
    margin-inline: auto;
    overflow: hidden;
  }
  .term-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    background: var(--surface-2);
    border-bottom: 1px solid var(--line);
  }
  .dot {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 50%;
    background: var(--line-strong);
  }
  .dot:nth-child(1) {
    background: #ff5f57;
  }
  .dot:nth-child(2) {
    background: #febc2e;
  }
  .dot:nth-child(3) {
    background: #28c840;
  }
  .term-title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--fg-faint);
  }
  .player-stage {
    padding: 0.2rem 0.3rem;
    min-height: 12rem;
  }
  .cast-mount {
    width: 100%;
    transition: opacity 0.15s ease;
  }
  /* When JS mounts the player: reserve its fitted height via a fixed aspect
     ratio (constant because fit:"width" scales the font with width). With
     overflow:hidden the ratio is authoritative — content can't override it — so
     asciinema's brief oversized first render is clipped and can NEVER reflow the
     card, independent of how long the fit takes. Gated on .js so the no-JS
     fallback (a <pre>) isn't pushed down by an empty reserved box. */
  :global(.js) .cast-mount {
    aspect-ratio: 1 / 0.5225;
    overflow: hidden;
  }
  /* Instant hide (no transition); revealed once asciinema has actually fitted. */
  .cast-mount.is-loading {
    opacity: 0;
    transition: none;
  }
  .cast-fallback {
    margin: 0;
    padding: 0.6rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--fg-muted);
    white-space: pre-wrap;
    overflow-x: auto;
  }

  .cli-tabs {
    display: flex;
    gap: 0.25rem;
    padding: 0.4rem 0.5rem;
    border-top: 1px solid var(--line);
    background: var(--surface-2);
  }
  .cli-tab {
    flex: 0 0 auto;
    padding: 0.5rem 0.95rem;
    border: none;
    background: transparent;
    border-radius: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--fg-muted);
    cursor: pointer;
    white-space: nowrap;
    transition:
      color 0.18s ease,
      background-color 0.18s ease;
  }
  .cli-tab:hover {
    color: var(--fg);
  }
  .cli-tab[aria-selected="true"] {
    color: var(--primary);
    background: color-mix(in srgb, var(--primary) 12%, transparent);
  }

  .cli-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
    margin-top: 2rem;
  }
</style>

<script>
  import * as AsciinemaPlayer from "asciinema-player";
  import "asciinema-player/dist/bundle/asciinema-player.css";

  const mount = () => {
    const root = document.querySelector<HTMLElement>("[data-cli-player]");
    if (!root || root.dataset.bound) return;
    const el = root.querySelector<HTMLElement>("#cli-cast");
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-tab]"));
    if (!el || !tabs.length) return;

    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let player: { dispose?: () => void } | null = null;
    let started = false;
    let currentSrc: string | null = null;

    const load = (src: string) => {
      currentSrc = src;
      if (player?.dispose) player.dispose();
      el.innerHTML = "";
      // The aspect-ratio box (CSS) keeps the card from reflowing; this hides the
      // brief oversized-font render until asciinema has applied its fit. How many
      // frames the fit takes varies by browser, so poll for it (the terminal
      // font shrinks below its unfitted ~19.8px default) rather than assuming a
      // fixed count; cap as a safety net so the player can't stay hidden.
      el.classList.add("is-loading");
      let tries = 0;
      const reveal = () => el.classList.remove("is-loading");
      const checkFitted = () => {
        const term = el.querySelector<HTMLElement>(".ap-term");
        const fitted = term && parseFloat(getComputedStyle(term).fontSize) < 18;
        if (fitted || tries++ > 40) reveal();
        else requestAnimationFrame(checkFitted);
      };
      requestAnimationFrame(checkFitted);
      player = AsciinemaPlayer.create(src, el, {
        autoPlay: !reduce,
        loop: !reduce,
        preload: true,
        controls: false,
        fit: "width",
        terminalFontFamily:
          "'JetBrains Mono Variable', ui-monospace, 'SF Mono', monospace",
        terminalLineHeight: 1.3,
        theme: "angr",
        poster: reduce ? "npt:9999:0" : undefined,
      });
    };

    const select = (tab: HTMLButtonElement) => {
      started = true;
      tabs.forEach((t) => {
        const on = t === tab;
        t.setAttribute("aria-selected", String(on));
        t.tabIndex = on ? 0 : -1;
      });
      load(tab.dataset.cast!);
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => select(tab));
      tab.addEventListener("keydown", (e) => {
        if (e.key !== "ArrowRight" && e.key !== "ArrowLeft") return;
        e.preventDefault();
        const dir = e.key === "ArrowRight" ? 1 : -1;
        const next = tabs[(i + dir + tabs.length) % tabs.length];
        next.focus();
        select(next);
      });
    });

    // Mount the first cast only when scrolled into view, so it plays from the
    // top when the visitor reaches it.
    const start = () => {
      root.dataset.bound = "1";
      if (!started) select(tabs[0]); // don't override a manual pick
    };
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries, obs) => {
          if (entries.some((e) => e.isIntersecting)) {
            obs.disconnect();
            start();
          }
        },
        { rootMargin: "0px 0px -20% 0px" }
      );
      io.observe(root);
    } else {
      start();
    }

    // asciinema bakes the palette into each drawn cell at render time, so a
    // theme toggle leaves already-painted cells in the old colors. Reload the
    // current cast when [data-theme] flips so the player re-reads the vars.
    // documentElement survives Astro view-transition swaps, so drop any
    // observer from a previous page before wiring up this mount's.
    const w = window as unknown as { __cliThemeObs?: MutationObserver };
    w.__cliThemeObs?.disconnect();
    const themeObserver = new MutationObserver(() => {
      if (currentSrc) load(currentSrc);
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
    w.__cliThemeObs = themeObserver;
  };

  mount();
  document.addEventListener("astro:after-swap", mount);
</script>
