---
import { features } from "@/data/features";
import Icon from "@/components/Icon.astro";
---

<section id="features" class="section">
  <div class="container-page">
    <header class="section-head reveal">
      <p class="kicker">// the toolkit</p>
      <h2>One platform, every analysis</h2>
      <p class="sub">
        angr brings static and dynamic techniques under a single, scriptable
        roof. Mix and match exactly what your problem needs.
      </p>
    </header>

    <ul class="grid" role="list">
      {
        features.map((f, i) => (
          <li
            class="card feature reveal"
            style={`--reveal-delay: ${(i % 4) * 70}ms`}
          >
            <span class="ic">
              <Icon name={f.icon} size={22} />
            </span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .section {
    padding-block: clamp(3.5rem, 7vw, 6rem);
  }
  .section-head {
    max-width: 42rem;
    margin-bottom: 3rem;
  }
  .section-head h2 {
    font-size: clamp(1.9rem, 4vw, 2.85rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.08;
    margin: 0.75rem 0 0.9rem;
  }
  .section-head .sub {
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--fg-muted);
  }

  .grid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 560px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 980px) {
    .grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .feature {
    padding: 1.5rem 1.4rem 1.6rem;
  }
  .feature:hover {
    border-color: var(--line-strong);
    box-shadow: 0 18px 40px -22px var(--ring);
  }
  .ic {
    display: inline-grid;
    place-items: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 0.75rem;
    color: var(--primary);
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--primary) 22%, transparent);
    margin-bottom: 1.1rem;
  }
  .feature h3 {
    font-size: 1.08rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0 0 0.5rem;
  }
  .feature p {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 0;
  }
</style>
